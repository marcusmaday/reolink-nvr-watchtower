# ─── Stats Endpoints ───────────────────────────────────────────────────────

@app.get("/api/stats", response_model=SystemStats, summary="Get system statistics")
async def get_stats():
    """Get system health and statistics."""
    try:
        storage_usage = await clip_generator.get_storage_usage()
        return SystemStats(
            status="ok" if nvr_client.is_connected else "error",
            nvr_connected=nvr_client.is_connected,
            event_subscribers=len(event_stream._subscribers),
            buffer_stats=video_buffer.get_stats(),
            timeline_stats=timeline_index.get_stats(),
            storage_usage=storage_usage,
        )
    except Exception as e:
        logger.error("Error getting stats: %s", e)
        raise HTTPException(status_code=500, detail=str(e))


# ─── WebSocket Endpoint ────────────────────────────────────────────────────

class ConnectionManager:
    def __init__(self):
        self.active_connections: List[WebSocket] = []

    async def connect(self, websocket: WebSocket):
        await websocket.accept()
        self.active_connections.append(websocket)
        logger.info("WebSocket connected. Total: %d", len(self.active_connections))

    def disconnect(self, websocket: WebSocket):
        self.active_connections.remove(websocket)
        logger.info("WebSocket disconnected. Total: %d", len(self.active_connections))

    async def broadcast(self, data: dict):
        for connection in self.active_connections:
            try:
                await connection.send_json(data)
            except Exception as e:
                logger.error("Error sending WebSocket message: %s", e)


manager = ConnectionManager()


@app.websocket("/ws/events")
async def websocket_endpoint(websocket: WebSocket):
    """
    WebSocket endpoint for real-time event streaming.
    Clients connect here to receive events as they occur.
    """
    await manager.connect(websocket)

    async def event_callback(event: Event):
        await manager.broadcast({
            "type": "event",
            "timestamp": event.timestamp.isoformat(),
            "channel": event.channel,
            "event_type": event.event_type.value,
            "event_id": event.event_id,
            "metadata": event.metadata,
        })

    # Subscribe to events
    unsubscribe = event_stream.subscribe(event_callback)

    try:
        while True:
            # Keep connection alive, receive any client messages
            data = await websocket.receive_text()
            # Echo back
            await websocket.send_text(f"Received: {data}")
    except WebSocketDisconnect:
        manager.disconnect(websocket)
        unsubscribe()
        logger.info("WebSocket closed")
    except Exception as e:
        logger.error("WebSocket error: %s", e)
        manager.disconnect(websocket)
        unsubscribe()


# ─── Debug Endpoint ────────────────────────────────────────────────────────

@app.get("/api/debug/info", summary="Debug information (debug mode only)")
async def debug_info():
    """Debug endpoint with detailed system information."""
    if not config.api.debug:
        raise HTTPException(status_code=403, detail="Debug endpoint disabled")

    return {
        "config": {
            "nvr_host": config.nvr.host,
            "nvr_port": config.nvr.port,
            "nvr_ssl": config.nvr.use_https,
            "buffer_enabled": config.video_buffer.enabled,
            "retention_days": config.storage.retention_days,
        },
        "state": {
            "nvr_connected": nvr_client.is_connected,
            "buffer_running": video_buffer._running if video_buffer else False,
            "event_stream_running": event_stream._running if event_stream else False,
        },
        "event_stream": event_stream.get_stats() if event_stream else None,
        "timeline": timeline_index.get_stats() if timeline_index else None,
    }


