{
  "name": "Reolink Enhanced API",
  "version": "0.2.0",
  "slug": "reolink_enhanced_api",
  "description": "REST + WebSocket API wrapper for Reolink NVR with event timeline and clip generation",
  "arch": ["aarch64", "amd64"],
  "startup": "services",
  "boot": "auto",
  "host_network": true,
  "ports": {
    "5000/tcp": 5000
  },
  "ports_description": {
    "5000/tcp": "API server port"
  },
  "image": "ghcr.io/marcusmaday/reolink-nvr-enhanced-{arch}",
  "options": {
    "nvr_host": "192.168.1.100",
    "nvr_port": 80,
    "nvr_username": "admin",
    "nvr_password": "password",
    "nvr_ssl": false,
    "buffer_enabled": true,
    "buffer_size_seconds": 60,
    "clip_duration_before": 5,
    "clip_duration_after": 5,
    "retention_days": 7,
    "max_storage_mb": 5000,
    "debug": false
  },
  "schema": {
    "nvr_host": "str",
    "nvr_port": "int(1,65535)",
    "nvr_username": "str",
    "nvr_password": "password",
    "nvr_ssl": "bool",
    "buffer_enabled": "bool",
    "buffer_size_seconds": "int(10,300)",
    "clip_duration_before": "int(1,30)",
    "clip_duration_after": "int(1,30)",
    "retention_days": "int(1,90)",
    "max_storage_mb": "int(100,20000)",
    "debug": "bool"
  },
  "homeassistant": "2024.1.0",
  "documentation": "https://github.com/marcusmaday/reolink-nvr-ha-app",
  "support": "https://github.com/marcusmaday/reolink-nvr-ha-app/issues"
}